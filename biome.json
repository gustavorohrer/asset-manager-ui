{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": [
      "src/**",
      "!**/node_modules",
      "!**/.next",
      "!**/out",
      "!**/build",
      "!**/coverage",
      "!**/backend-mock",
      "!**/.aiassistant",
      "!next-env.d.ts"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
